+static int                          /* O - 1 if user_* attr, 0 otherwise */
+is_user_attr(ipp_attribute_t *attr) /* I - Attribute to check */
+{
+  return (attr->group_tag == IPP_TAG_JOB && !strncmp(attr->name, "user_", 5));
+}
+
+/*
+ * 'user_attr_length()' - Compute the size needed for a single user_*
+ *		        attribute in the CUPS options format string.
+ */
+
+static size_t                           /* O - Size in bytes */
+user_attr_length(ipp_attribute_t *attr) /* I - Attribute */
+{
+  size_t attr_bytes; /* Size of attribute text */
+  int i;             /* Looping var */
+
+  attr_bytes = 1;                         /* " " separator */
+  attr_bytes += (size_t)attr->num_values; /* "," separators */
+
+  if (attr->value_tag != IPP_TAG_BOOLEAN)
+    attr_bytes += strlen(attr->name);
+  else
+    attr_bytes += (size_t)attr->num_values * strlen(attr->name);
+
+  switch (attr->value_tag)
+  {
+  case IPP_TAG_INTEGER:
+  case IPP_TAG_ENUM:
+    attr_bytes += (size_t)attr->num_values * 11;
+    break;
+
+  case IPP_TAG_BOOLEAN:
+    /*
+     * Add two bytes for each false ("no") value...
+     */
+
+    for (i = 0; i < attr->num_values; i++)
+      if (!attr->values[i].boolean)
+        attr_bytes += 2;
+    break;
+
+  case IPP_TAG_RANGE:
+    attr_bytes += (size_t)attr->num_values * 23;
+    break;
+
+  case IPP_TAG_RESOLUTION:
+    attr_bytes += (size_t)attr->num_values * 26;
+    break;
+
+  case IPP_TAG_STRING:
+    /*
+     * Octet strings can contain characters that need quoting.
+     * We need at least 2 * len + 2 characters to cover the
+     * quotes and any backslashes in the string.
+     */
+
+    for (i = 0; i < attr->num_values; i++)
+      attr_bytes += 2 * (size_t)attr->values[i].unknown.length + 2;
+    break;
+
+  case IPP_TAG_TEXT:
+  case IPP_TAG_NAME:
+  case IPP_TAG_KEYWORD:
+  case IPP_TAG_CHARSET:
+  case IPP_TAG_LANGUAGE:
+  case IPP_TAG_URI:
+    /*
+     * Strings can contain characters that need quoting.
+     * We need at least 2 * len + 2 characters to cover
+     * the quotes and any backslashes in the string.
+     */
+
+    for (i = 0; i < attr->num_values; i++)
+      attr_bytes += 2 * strlen(attr->values[i].string.text) + 2;
+    break;
+
+  default:
+    break; /* anti-compiler-warning-code */
+  }
+
+  return (attr_bytes);
+}
+
+/*
+ * 'format_attr_to_buf()' - Format an IPP attribute into a CUPS options
+ *                          format string and append to the given buffer.
+ */
+
+static char * /* O - New pointer position */
+format_attr_to_buf(
+    ipp_attribute_t *attr, /* I - Attribute to format */
+    char *ptr,             /* I - Current position in buffer */
+    char *base,            /* I - Start of buffer */
+    size_t buflen)         /* I - Total buffer length */
+{
+  int i;        /* Looping var */
+  char *valptr; /* Pointer into value string */
+
+  if (ptr > base)
+    strlcat(ptr, " ", buflen - (size_t)(ptr - base));
+
+  if (attr->value_tag != IPP_TAG_BOOLEAN)
+  {
+    strlcat(ptr, attr->name, buflen - (size_t)(ptr - base));
+    strlcat(ptr, "=", buflen - (size_t)(ptr - base));
+  }
+
+  for (i = 0; i < attr->num_values; i++)
+  {
+    if (i)
+      strlcat(ptr, ",", buflen - (size_t)(ptr - base));
+
+    ptr += strlen(ptr);
+
+    switch (attr->value_tag)
+    {
+    case IPP_TAG_INTEGER:
+    case IPP_TAG_ENUM:
+      snprintf(ptr, buflen - (size_t)(ptr - base),
+               "%d", attr->values[i].integer);
+      break;
+
+    case IPP_TAG_BOOLEAN:
+      if (!attr->values[i].boolean)
+        strlcat(ptr, "no", buflen - (size_t)(ptr - base));
+
+      strlcat(ptr, attr->name, buflen - (size_t)(ptr - base));
+      break;
+
+    case IPP_TAG_RANGE:
+      if (attr->values[i].range.lower == attr->values[i].range.upper)
+        snprintf(ptr, buflen - (size_t)(ptr - base) - 1,
+                 "%d", attr->values[i].range.lower);
+      else
+        snprintf(ptr, buflen - (size_t)(ptr - base) - 1,
+                 "%d-%d", attr->values[i].range.lower,
+                 attr->values[i].range.upper);
+      break;
+
+    case IPP_TAG_RESOLUTION:
+      snprintf(ptr, buflen - (size_t)(ptr - base) - 1,
+               "%dx%d%s", attr->values[i].resolution.xres,
+               attr->values[i].resolution.yres,
+               attr->values[i].resolution.units == IPP_RES_PER_INCH ? "dpi" : "dpcm");
+      break;
+
+    case IPP_TAG_STRING:
+    {
+      int length = attr->values[i].unknown.length;
+
+      for (valptr = attr->values[i].unknown.data; length > 0; length--)
+      {
+        if ((*valptr & 255) < 0x20 || *valptr == 0x7f)
+          break;
+      }
+
+      if (length > 0)
+      {
+        /*
+         * Encode this string as hex characters...
+         */
+
+        *ptr++ = '<';
+
+        for (valptr = attr->values[i].unknown.data, length = attr->values[i].unknown.length; length > 0; length--)
+        {
+          snprintf(ptr, buflen - (size_t)(ptr - base) - 1, "%02X", *valptr & 255);
+          ptr += 2;
+        }
+
+        *ptr++ = '>';
+      }
+      else
+      {
+        for (valptr = attr->values[i].unknown.data, length = attr->values[i].unknown.length; length > 0; length--)
+        {
+          if (strchr(" \t\n\\\'\"", *valptr))
+            *ptr++ = '\\';
+          *ptr++ = *valptr++;
+        }
+      }
+    }
+
+      *ptr = '\0';
+      break;
+
+    case IPP_TAG_TEXT:
+    case IPP_TAG_NAME:
+    case IPP_TAG_KEYWORD:
+    case IPP_TAG_CHARSET:
+    case IPP_TAG_LANGUAGE:
+    case IPP_TAG_URI:
+      for (valptr = attr->values[i].string.text; *valptr;)
+      {
+        if (strchr(" \t\n\\\'\"", *valptr))
+          *ptr++ = '\\';
+        *ptr++ = *valptr++;
+      }
+
+      *ptr = '\0';
+      break;
+
+    default:
+      break; /* anti-compiler-warning-code */
+    }
+
+    ptr += strlen(ptr);
+  }
+
+  return (ptr);
+}
 
